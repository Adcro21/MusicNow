@model MUSICNOW.Core.ViewModels.HomeViewModel
@using System.Linq
@{
    ViewBag.Title = "Trang Chủ";
    ViewBag.ActivePage = "NoiBat"; // Đặt trang active cho Sidebar
}

@* (CSS - ĐÃ CẬP NHẬT HOÀN CHỈNH) *@
@section styles {
    <style>
        /* (CSS .spotify-card, .spotify-play-button giữ nguyên) */
        .spotify-card-wrapper {
            position: relative;
        }

        .spotify-card {
            background-color: #181818;
            border-radius: 8px;
            transition: background-color 0.3s ease;
            position: relative;
            padding: 1rem;
        }

            .spotify-card:hover {
                background-color: #282828;
            }

            .spotify-card img {
                border-radius: 6px;
                width: 100%;
                height: auto;
                aspect-ratio: 1 / 1;
                object-fit: cover;
                margin-bottom: 1rem;
            }

        .spotify-play-button {
            position: absolute;
            bottom: 7rem;
            right: 1.5rem;
            background-color: #1DB954;
            color: #000;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            font-size: 1.5rem;
            line-height: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
            opacity: 0;
            transform: translateY(10px);
            transition: all 0.2s ease-out;
            z-index: 10;
        }

        .spotify-card-wrapper:hover .spotify-play-button {
            opacity: 1;
            transform: translateY(0);
        }

        .spotify-play-button:hover {
            background-color: #1ed760;
            transform: scale(1.05);
            color: #000;
        }

        /* (CSS .spotify-card-actions, .btn-icon giữ nguyên) */
        .spotify-card-actions {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            display: flex;
            gap: 0.25rem;
            opacity: 0;
            transition: all 0.2s ease-out;
            z-index: 11;
        }

        .spotify-card-wrapper:hover .spotify-card-actions {
            opacity: 1;
        }

        .btn-icon {
            background-color: rgba(0,0,0,0.5);
            color: #fff;
            border: none;
            border-radius: 50%;
            width: 32px;
            height: 32px;
            font-size: 1rem;
            display: flex;
            justify-content: center;
            align-items: center;
        }

            .btn-icon:hover {
                background-color: rgba(0,0,0,0.8);
                transform: scale(1.1);
                color: #fff;
            }

        /* === SỬA LẠI CSS CHO NÚT LIKE (DÙNG FONT AWESOME) === */
        /* Định nghĩa chung cho icon tim */
        .btn-like .fa-heart {
            transition: all 0.2s ease;
            font-size: 1rem; /* Đảm bảo kích thước */
        }
        /* Icon rỗng (chưa like) */
        .btn-like .fa-regular {
            color: #b3b3b3;
        }
        /* Icon đặc (đã like) */
        .btn-like .fa-solid {
            color: #1DB954;
            /* Màu xanh lá */
        }
        /* Hover */
        .btn-like:hover .fa-heart {
            color: #fff;
        }
        /* === KẾT THÚC SỬA CSS === */

        /* (CSS cho Bảng Xếp Hạng - Giữ nguyên) */
        .list-item-hover {
            transition: background-color 0.2s ease;
        }

            .list-item-hover:hover {
                background-color: #2a2a2a !important;
            }

        .btn-play-small-list {
            background: none;
            border: 1px solid #b3b3b3;
            color: #fff;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            font-size: 0.8rem;
            line-height: 1;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: all 0.2s ease;
        }

        .list-item-hover:hover .btn-play-small-list {
            opacity: 1;
        }

        .btn-play-small-list:hover {
            border-color: #1DB954;
            color: #1DB954;
            transform: scale(1.1);
        }
    </style>
}

@* --- BẮT ĐẦU HTML BODY --- *@
<h3 class="mt-4">Chào buổi tối,</h3>

@* --- 1. KHU VỰC BÀI HÁT THỊNH HÀNH --- *@
<div class="section mb-5">
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="h5">Những bài hát thịnh hành</h4>
        @Html.ActionLink("Xem tất cả", "SeeAll", "Music", new { listType = "trending" }, new { @class = "text-info small", style = "color: #1DB954 !important;" })
    </div>

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4 mt-1">

        @if (Model.TrendingTracks != null && Model.TrendingTracks.Any())
        {
            foreach (var track in Model.TrendingTracks)
            {
                <div class="col">
                    <div class="spotify-card-wrapper">

                        <div class="spotify-card p-0">

                            <button class="btn spotify-play-button"
                                    data-filepath="@track.FilePath"
                                    data-musicid="@track.MusicID"
                                    data-title="@track.Title"
                                    data-artist="@track.SingerName"
                                    onclick="playTrack(this)">
                                ▶️
                            </button>


                            <img src="@Url.Content(track.CoverArtUrl ?? "~/Content/image/music_placeholder.png")"
                                 class="card-img-top p-3"
                                 alt="@track.Title">


                            <div class="card-body p-3 pt-0">
                                <small class="text-truncate d-block" style="font-weight: bold; color: #fff;">@track.Title</small>
                                <small class="text-muted text-truncate d-block">@track.SingerName</small>
                            </div>
                        </div>


                        <div class="spotify-card-actions">
                            @{
                                bool isLiked = Model.LikedMusicIds.Contains(track.MusicID);
                            }

                            <button class="btn-icon btn-like"
                                    data-musicid="@track.MusicID"
                                    onclick="toggleLike(this, @track.MusicID)">
                                @if (isLiked)
                                {
                                    <i class="fa-solid fa-heart"></i> }
                                else
                                {
                                    <i class="fa-regular fa-heart"></i>}
                            </button>

                            <div class="dropdown">

                                <button class="btn-icon btn-more" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    ...
                                </button>

                                <ul class="dropdown-menu dropdown-menu-dark">
                                    @if (Model.UserPlaylists != null && Model.UserPlaylists.Any())
                                    {
                                        <li><h6 class="dropdown-header">Thêm vào playlist</h6></li>
                                        foreach (var playlist in Model.UserPlaylists)
                                        {
                                            <li>

                                                <a class="dropdown-item" href="#"
                                                   onclick="addToPlaylist(event, @track.MusicID, @playlist.PlaylistID)">

                                                    @playlist.Name
                                                </a>

                                            </li>
                                        }
                                    }

                                    else
                                    {
                                        <li><span class="dropdown-item-text text-muted">Bạn chưa có playlist nào.</span></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>

                                    <li><a class="dropdown-item" href="#">Chia sẻ (Demo)</a></li>
                                </ul>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12"><p class="text-muted">Chưa có bài hát nào được tải lên.</p></div>
        }

    </div>
</div>

@* --- 2. KHU VỰC BẢNG XẾP HẠNG (Giữ nguyên) --- *@
<div class="section mb-4">
    <h4 class="h5">Bảng xếp hạng</h4>
    <div class="row mt-3">
        <div class="col-md-6">
            <h6 style="color: #1DB954;">Top bài hát thịnh hành</h6>
            <ul class="list-group list-group-flush" style="background-color: transparent;">
                @if (Model.Top50Global != null && Model.Top50Global.Any())
                {
                    for (int i = 0; i < Model.Top50Global.Count; i++)
                    {
                        var track = Model.Top50Global[i];
                        <li class="list-group-item d-flex align-items-center list-item-hover"
                            style="background-color: transparent; border: none; padding: 8px 0; border-radius: 4px;">

                            <span style="color: #b3b3b3; margin-right: 15px; min-width: 20px;">@(i + 1)</span>


                            <img src="@Url.Content(track.CoverArtUrl ?? "~/Content/image/music_placeholder.png")"
                                 alt="@track.Title"
                                 style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px; margin-right: 15px;">


                            <span class="flex-grow-1 text-truncate">@track.Title - <span style="color: #b3b3b3;">@track.SingerName</span></span>

                            <button class="btn btn-play-small-list"
                                    data-filepath="@track.FilePath"
                                    data-musicid="@track.MusicID"
                                    data-title="@track.Title"
                                    data-artist="@track.SingerName"
                                    onclick="playTrackSmall(this)">
                                ▶️
                            </button>

                        </li>
                    }
                }
                else
                {
                    <li class="list-group-item"
                        style="background-color: transparent; border: none; color: #b3b3b3;">Chưa có dữ liệu.</li>
                }
            </ul>
        </div>

        @*<div class="col-md-6">
            <h6 style="color: #FFC107;">Top Bài hát được nghe nhiều nhất</h6>
            <ul class="list-group list-group-flush" style="background-color: transparent;">

                @if (Model.Top50VN != null && Model.Top50VN.Any())
                {
                    for (int i = 0; i < Model.Top50VN.Count; i++)
                    {
                        var track = Model.Top50VN[i];

                        <li class="list-group-item d-flex align-items-center list-item-hover"
                            style="background-color: transparent; border: none; padding: 8px 0; border-radius: 4px;">

                            <span style="color: #b3b3b3; margin-right: 15px; min-width: 20px;">@(i + 1)</span>

                            <img src="@Url.Content(track.CoverArtUrl ?? "~/Content/image/music_placeholder.png")"
                                 alt="@track.Title"
                                 style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px; margin-right: 15px;">

                            <span class="flex-grow-1 text-truncate">@track.Title - <span style="color: #b3b3b3;">@track.SingerName</span></span>

                            <button class="btn btn-play-small-list"
                                    data-filepath="@track.FilePath"
                                    data-musicid="@track.MusicID"
                                    data-title="@track.Title"
                                    data-artist="@track.SingerName"
                                   onclick="playTrackSmall(this)">
                                ▶️

                            </button>
                        </li>
                    }
                }
                else
                {

                    <li class="list-group-item" style="background-color: transparent; border: none; color: #b3b3b3;">Chưa có dữ liệu.</li>
                }
            </ul>
        </div>*@
    </div>
</div>

@* --- 3. KHU VỰC NGHỆ SĨ (ĐÃ SỬA LẠI THEO Ý BẠN) --- *@
<div class="section mb-5">
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="h5">Nghệ Sĩ Nổi Bật</h4>
        @Html.ActionLink("Xem tất cả", "SeeAll", "Music", new { listType = "artists" }, new { @class = "text-info small", style = "color: #1DB954 !important;" })
    </div>

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-4 mt-1">

        @if (Model.PopularArtists != null && Model.PopularArtists.Any())
        {
            foreach (var artist in Model.PopularArtists)
            {
                <div class="col">
                    @* Bọc TOÀN BỘ thẻ card trong 1 thẻ <a> *@
                    <a href="@Url.Action("Details", "Artist", new { id = artist.UserID })" style="text-decoration: none;">

                        <div class="spotify-card p-0">

                            @* Ảnh vuông (giống thẻ bài hát) *@
                            <img src="@Url.Content(artist.AvatarUrl ?? "~/Content/image/avt.png")"
                                 class="card-img-top"
                                 alt="@artist.Username">

                            @* Chữ căn trái (giống thẻ bài hát) *@
                            <div class="card-body p-3 pt-0">
                                <small class="text-truncate d-block" style="font-weight: bold; color: #fff;">
                                    @artist.Username
                                </small>
                                <small class="text-muted text-truncate d-block">Nghệ sĩ</small>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12"><p class="text-muted">Chưa có nghệ sĩ nào.</p></div>
        }
    </div>
</div>
@* --- KẾT THÚC KHU VỰC NGHỆ SĨ --- *@


@* (JavaScript - ĐÃ CẬP NHẬT HOÀN CHỈNH) *@
@section scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Hàm này (playTrack) giờ sẽ xây dựng hàng đợi cho Card Lớn
            window.playTrack = function (buttonElement) {
                // 1. Tìm container cha (nơi chứa tất cả bài hát)
                var container = $(buttonElement).closest('.section');
                // 2. Tìm tất cả các nút play trong container đó
                var allPlayButtons = container.find('.spotify-play-button');

                var queue = [];
                var startIndex = 0;

                // 3. Lặp qua tất cả nút để xây dựng hàng đợi
                allPlayButtons.each(function (index, btn) {
                    var track = {
                        filePath: $(btn).data('filepath'),
                        musicId: $(btn).data('musicid'),
                        title: $(btn).data('title'),
                        artist: $(btn).data('artist'),
                        // Lấy ảnh từ thẻ <img> anh em
                        coverArtUrl: $(btn).siblings('img').attr('src')
                    };
                    queue.push(track);

                    // Nếu nút này là nút vừa được click
                    if (btn === buttonElement) {
                        startIndex = index;
                    }
                });

                // 4. Gửi hàng đợi đến Player Toàn Cục
                window.startQueue(queue, startIndex);
            }

            // Hàm này (playTrackSmall) sẽ xây dựng hàng đợi cho List Nhỏ (Bảng xếp hạng)
            window.playTrackSmall = function (buttonElement) {
                // 1. Tìm container cha (ul)
                var container = $(buttonElement).closest('ul');
                // 2. Tìm tất cả các nút play trong container đó
                var allPlayButtons = container.find('.btn-play-small-list');

                var queue = [];
                var startIndex = 0;

                allPlayButtons.each(function (index, btn) {
                    var track = {
                        filePath: $(btn).data('filepath'),
                        musicId: $(btn).data('musicid'),
                        title: $(btn).data('title'),
                        artist: $(btn).data('artist'),
                        // Lấy ảnh từ thẻ <img> anh em
                        coverArtUrl: $(btn).siblings('img').attr('src')
                    };
                    queue.push(track);

                    if (btn === buttonElement) {
                        startIndex = index;
                    }
                });

                // 4. Gửi hàng đợi đến Player Toàn Cục
                window.startQueue(queue, startIndex);
            }

            // === CÁC HÀM AJAX CŨ (Like, AddToPlaylist) VẪN GIỮ NGUYÊN ===
            window.toggleLike = function (buttonElement, musicId) {
                var token = $('input[name="__RequestVerificationToken"]').val();
                if (!token) {
                    token = $("#__AjaxAntiForgeryForm input[name='__RequestVerificationToken']").val();
                }

                $.ajax({
                    url: '/Music/ToggleLike/' + musicId,
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        if (response.success) {
                            var icon = buttonElement.querySelector('i.fa-heart');
                            if (icon) {
                                if (response.liked) {
                                    icon.classList.remove('fa-regular');
                                    icon.classList.add('fa-solid');
                                } else {
                                    icon.classList.remove('fa-solid');
                                    icon.classList.add('fa-regular');
                                }
                            }
                        } else {
                            alert(response.error || "Có lỗi xảy ra.");
                        }
                    },
                    error: function (xhr) {
                        if (xhr.status === 401) {
                            alert("Bạn cần đăng nhập để thực hiện chức năng này.");
                        } else {
                            alert("Đã xảy ra lỗi. Vui lòng thử lại.");
                        }
                    }
                });
            };

            window.addToPlaylist = function (event, musicId, playlistId) {
                event.preventDefault();
                var token = $('input[name="__RequestVerificationToken"]').val();
                if (!token) {
                    token = $("#__AjaxAntiForgeryForm input[name='__RequestVerificationToken']").val();
                }

                $.ajax({
                    url: '/Music/AddSongToPlaylist',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token,
                        musicId: musicId,
                        playlistId: playlistId
                    },
                    success: function (response) {
                        alert(response.message);
                    },
                    error: function (xhr) {
                        if (xhr.status === 401) {
                            alert("Bạn cần đăng nhập để thực hiện chức năng này.");
                        } else {
                            alert("Đã xảy ra lỗi. Vui lòng thử lại.");
                        }
                    }
                });
            };

        });
    </script>
}