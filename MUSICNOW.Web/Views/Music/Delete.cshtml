@model MUSICNOW.Core.ViewModels.TrackViewModel
@{
    ViewBag.Title = "Xác Nhận Xóa Bài Hát";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <style>
        .profile-container {
            max-width: 1200px;
            margin: auto;
        }

        .dark-card {
            background-color: #1E1E1E;
            border: none;
            border-radius: 10px;
        }

        .card-title-danger {
            color: #dc3545;
            border-bottom: 1px solid #333;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .delete-track-info {
            display: flex;
            align-items: center;
            gap: 15px;
            background-color: #2a2a2a;
            padding: 10px;
            border-radius: 8px;
        }

        .delete-cover-art {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 5px;
        }
    </style>
}

<div class="profile-container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card p-4 dark-card">
                <h2 class="card-title-danger">Xác Nhận Xóa</h2>
                <hr style="border-color: #444;" />

                <p class="text-light">
                    Bạn có chắc chắn muốn xóa vĩnh viễn bài hát này không? <br />
                    (Hành động này sẽ xóa nó khỏi tất cả playlist và danh sách yêu thích).
                </p>

                <div class="delete-track-info my-3">
                    <img src="@Url.Content(Model.CoverArtUrl ?? "~/Content/image/music_placeholder.png")"
                         alt="@Model.Title"
                         class="delete-cover-art" />
                    <div>
                        <h4 class="text-warning" style="margin-bottom: 0;">@Model.Title</h4>
                        <p class="text-muted">@Model.SingerName</p>
                    </div>
                </div>

                @using (Html.BeginForm("DeleteConfirmed", "Music", new { id = Model.MusicID }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-danger w-100 mt-3">
                        Vâng, Xóa Bài Hát Này
                    </button>
                    <a href="@Url.Action("MyMusic", "Music")" class="btn btn-secondary w-100 mt-2">
                        Hủy
                    </a>
                }
            </div>
        </div>
    </div>
</div>