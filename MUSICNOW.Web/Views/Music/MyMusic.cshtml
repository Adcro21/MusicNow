@model List<MUSICNOW.Core.ViewModels.TrackViewModel>
@{
    ViewBag.Title = "Nhạc Của Bạn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <style>
        .table-dark-custom {
            background-color: #1E1E1E;
            color: #fff;
        }

            .table-dark-custom th {
                background-color: #2a2a2a;
                color: #1DB954;
                border-bottom: 1px solid #444;
            }

            .table-dark-custom td {
                border-bottom: 1px solid #333;
                vertical-align: middle;
            }

            .table-dark-custom tbody tr:hover {
                background-color: #2a2a2a;
            }

        .cover-art-thumb {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 5px;
        }
    </style>
}

<div class="container-fluid content-container mt-4">
    <h2 class="section-title">🎵 Nhạc của bạn</h2>
    <p class="text-muted">Quản lý các bài hát bạn đã tải lên.</p>

    <div class="card p-3 dark-card mt-4" style="background-color: #1E1E1E; border: none;">

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-dark-custom table-hover align-middle">
                    <thead>
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Ảnh bìa</th>
                            <th scope="col">Tên bài hát</th>
                            <th scope="col">Nghệ sĩ</th>

                            @* === THÊM DÒNG NÀY === *@
                            <th scope="col">Lượt xem</th>

                            <th scope="col" style="width: 15%;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var track = Model[i];
                            <tr>
                                <th scope="row">@(i + 1)</th>
                                <td>
                                    <img src="@Url.Content(track.CoverArtUrl ?? "~/Content/image/music_placeholder.png")"
                                         alt="@track.Title"
                                         class="cover-art-thumb" />
                                </td>
                                <td>@track.Title</td>
                                <td>@track.SingerName</td>

                                @* === THÊM DÒNG NÀY === *@
                                <td>@track.Views.ToString("N0")</td> @* "N0" để format số (vd: 1,234) *@

                                <td>
                                    <a href="@Url.Action("Edit", "Music", new { id = track.MusicID })" class="btn btn-outline-warning btn-sm">Chỉnh sửa</a>
                                    <a href="@Url.Action("Delete", "Music", new { id = track.MusicID })" class="btn btn-outline-danger btn-sm">Xóa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @* (Phần "Bạn chưa đăng bài hát nào" giữ nguyên) *@
            <div class="text-center p-5">
                <p class="h5 text-muted">Bạn chưa đăng bài hát nào.</p>
                @if ((bool)(ViewData["CanUpload"] ?? false))
                {
                    <a href="@Url.Action("Upload", "Music")" class="btn btn-success mt-3">Tải lên bài hát đầu tiên</a>
                }
            </div>
        }
    </div>
</div>

