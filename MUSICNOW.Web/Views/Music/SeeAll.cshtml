@model object
@* Dùng 'object' vì Action có thể trả về List<TrackViewModel> hoặc List<ProfileViewModel> *@
@{
    ViewBag.Title = ViewBag.Title ?? "Xem Tất Cả";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Kiểm tra kiểu dữ liệu của Model
    var tracks = Model as List<MUSICNOW.Core.ViewModels.TrackViewModel>;
    var artists = Model as List<MUSICNOW.Core.ViewModels.ProfileViewModel>;
}

@section styles {
    <style>
        /* CSS cho danh sách bài hát */
        .list-item-hover {
            transition: background-color 0.2s ease;
        }

            .list-item-hover:hover {
                background-color: #2a2a2a !important;
            }

        .btn-play-small-list {
            background: none;
            border: 1px solid #b3b3b3;
            color: #fff;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            font-size: 0.8rem;
            line-height: 1;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: all 0.2s ease;
        }

        .list-item-hover:hover .btn-play-small-list {
            opacity: 1;
        }

        .btn-play-small-list:hover {
            border-color: #1DB954;
            color: #1DB954;
            transform: scale(1.1);
        }

        .cover-art-thumb {
            width: 40px;
            height: 40px;
            object-fit: cover;
            border-radius: 4px;
            margin-right: 15px;
        }

        /* CSS cho danh sách nghệ sĩ (Giống Index) */
        .spotify-card {
            background-color: #181818;
            border-radius: 8px;
            transition: background-color 0.3s ease;
            position: relative;
            padding: 1rem;
        }

            .spotify-card:hover {
                background-color: #282828;
            }

            .spotify-card img {
                border-radius: 6px;
                width: 100%;
                height: auto;
                aspect-ratio: 1 / 1;
                object-fit: cover;
                margin-bottom: 1rem;
            }
    </style>
}

<div class="container-fluid content-container mt-4">
    <h2 class="h4">@ViewBag.Title</h2>
    <hr style="border-color: #333;" />

    @* TRƯỜNG HỢP 1: HIỂN THỊ DANH SÁCH BÀI HÁT *@
    @if (tracks != null)
    {
        <ul class="list-group list-group-flush mt-4" style="background-color: transparent;">
            @foreach (var track in tracks)
            {
                <li class="list-group-item d-flex align-items-center list-item-hover" style="background-color: transparent; border: none; padding: 8px 0;">
                    <img src="@Url.Content(track.CoverArtUrl ?? "~/Content/image/music_placeholder.png")" alt="@track.Title" class="cover-art-thumb">
                    <span class="flex-grow-1 text-truncate">@track.Title - <span style="color: #b3b3b3;">@track.SingerName</span></span>
                    <button class="btn btn-play-small-list"
                            data-filepath="@track.FilePath"
                            data-musicid="@track.MusicID"
                            data-title="@track.Title"
                            data-artist="@track.SingerName"
                            onclick="playTrackList(this)">
                        @* <-- Sửa tên hàm *@
                        ▶️
                    </button>
                </li>
            }
        </ul>
    }

    @* TRƯỜNG HỢP 2: HIỂN THỊ DANH SÁCH NGHỆ SĨ *@
    @if (artists != null)
    {
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3 mb-5 mt-3">
            @foreach (var artist in artists)
            {
                <div class="col">
                    <a href="@Url.Action("Details", "Artist", new { id = artist.UserID })" style="text-decoration: none;">
                        <div class="spotify-card p-0">
                            <img src="@Url.Content(artist.AvatarUrl ?? "~/Content/image/avt.png")"
                                 class="card-img-top"
                                 alt="@artist.Username">
                            <div class="card-body p-3 pt-0">
                                <small class="text-truncate d-block" style="font-weight: bold; color: #fff;">
                                    @artist.Username
                                </small>
                                <small class="text-muted text-truncate d-block">Nghệ sĩ</small>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>

@* === SỬA TOÀN BỘ LOGIC SCRIPT === *@
@section scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Hàm này (playTrackList) sẽ xây dựng hàng đợi cho list nhạc
            window.playTrackList = function (buttonElement) {
                var container = $(buttonElement).closest('ul');
                var allPlayButtons = container.find('.btn-play-small-list');
                var queue = [];
                var startIndex = 0;

                allPlayButtons.each(function (index, btn) {
                    var track = {
                        filePath: $(btn).data('filepath'),
                        musicId: $(btn).data('musicid'),
                        title: $(btn).data('title'),
                        artist: $(btn).data('artist'),
                        coverArtUrl: $(btn).siblings('img').attr('src')
                    };
                    queue.push(track);
                    if (btn === buttonElement) {
                        startIndex = index;
                    }
                });
                window.startQueue(queue, startIndex);
            }

        });
    </script>
}