@model MUSICNOW.Core.ViewModels.SearchViewModel
@{
    ViewBag.Title = $"Kết quả cho '{Model.SearchTerm}'";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* (Thêm CSS cho bảng - giống hệt MyMusic.cshtml) *@
@section styles {
    <style>
        .list-item-hover {
            transition: background-color 0.2s ease;
        }

            .list-item-hover:hover {
                background-color: #2a2a2a !important;
            }

        .btn-play-small-list {
            background: none;
            border: 1px solid #b3b3b3;
            color: #fff;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            font-size: 0.8rem;
            line-height: 1;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: all 0.2s ease;
        }

        .list-item-hover:hover .btn-play-small-list {
            opacity: 1;
        }

        .btn-play-small-list:hover {
            border-color: #1DB954;
            color: #1DB954;
            transform: scale(1.1);
        }

        .cover-art-thumb {
            width: 40px;
            height: 40px;
            object-fit: cover;
            border-radius: 4px;
            margin-right: 15px;
        }
    </style>
}

<div class="container-fluid content-container mt-4">
    <h2 class="section-title">Kết quả tìm kiếm cho "@Model.SearchTerm"</h2>

    <ul class="list-group list-group-flush mt-4" style="background-color: transparent;">

        @if (Model.HasResults)
        {
            int counter = 1;
            foreach (var track in Model.Results)
            {
                <li class="list-group-item d-flex align-items-center list-item-hover"
                    style="background-color: transparent; border: none; padding: 8px 0; border-radius: 4px;">

                    <span style="color: #b3b3b3; margin-right: 15px; min-width: 20px;">@(counter++)</span>

                    <img src="@Url.Content(track.CoverArtUrl ?? "~/Content/image/music_placeholder.png")"
                         alt="@track.Title"
                         class="cover-art-thumb">

                    <span class="flex-grow-1 text-truncate">@track.Title - <span style="color: #b3b3b3;">@track.SingerName</span></span>

                    <button class="btn btn-play-small-list"
                            data-filepath="@track.FilePath"
                            data-musicid="@track.MusicID"
                            data-title="@track.Title"
                            data-artist="@track.SingerName"
                            onclick="playTrack(this)">
                        ▶️
                    </button>

                </li>
            }
        }
        else
        {
            <li class="list-group-item text-muted" style="background-color: transparent; border: none;">
                Không tìm thấy kết quả nào cho "@Model.SearchTerm".
            </li>
        }
    </ul>
</div>

@* (JavaScript - Cần hàm playTrack() toàn cục) *@
@section scripts {
    <script>
        // Tạm thời, chúng ta sao chép lại hàm playTrack() vào đây
        document.addEventListener('DOMContentLoaded', function () {
            var audioPlayer = document.getElementById('audio-player-fixed');
            var playerTitle = document.getElementById('player-title');
            var playerArtist = document.getElementById('player-artist');

            if (!audioPlayer) {
                console.error('Lỗi: Player không tìm thấy!');
                return;
            }

            if (typeof window.playTrack === 'undefined') {
                window.playTrack = function (buttonElement) {
                    var filePath = buttonElement.getAttribute('data-filepath');
                    var musicId = buttonElement.getAttribute('data-musicid');
                    var title = buttonElement.getAttribute('data-title');
                    var artist = buttonElement.getAttribute('data-artist');

                    if (filePath) {
                        audioPlayer.src = filePath;
                        audioPlayer.play();
                        if(playerTitle) playerTitle.textContent = title;
                        if(playerArtist) playerArtist.textContent = artist;
                        if (musicId) {
                            $.post("/Music/IncrementViewCount/" + musicId);
                        }
                    }
                }
            }
        });
    </script>
}