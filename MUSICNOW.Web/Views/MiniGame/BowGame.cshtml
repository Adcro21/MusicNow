@{
    // Quan trọng: Tắt _Layout.cshtml để file này là một trang độc lập
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Bow Game</title>

    @* === CSS CỦA GAME === *@
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #222;
            overflow: hidden;
            color: white;
            font-family: Arial, sans-serif;
        }

        #game-svg {
            width: 100%;
            height: 100%;
            cursor: none; /* Ẩn con trỏ, chúng ta sẽ vẽ crosshair */
        }

        .bow {
            stroke: #F0E68C;
            stroke-width: 4;
            fill: none;
        }

        .string {
            stroke: #fff;
            stroke-width: 2;
        }

        .arrow {
            fill: #CD853F;
            stroke: #000;
            stroke-width: 1;
        }

        .target {
            fill: #B22222;
        }

        .target-center {
            fill: #FFD700;
        }

        .crosshair {
            stroke: rgba(255, 0, 0, 0.7);
            stroke-width: 2;
        }
    </style>
</head>
<body>

    @* === HTML/SVG CỦA GAME (ĐÃ SỬA) === *@

    @* SỬA DÒNG NÀY: Thêm viewBox="0 0 900 500" *@
    <svg id="game-svg" viewBox="0 0 900 500">
        <g id="target">
            <circle cx="800" cy="250" r="50" class="target"></circle>
            <circle cx="800" cy="250" r="30" class="target" style="fill: #fff;"></circle>
            <circle cx="800" cy="250" r="10" class="target-center"></circle>
        </g>
        <g id="bow-pivot" transform="rotate(0, 100, 250)">
            <path d="M 100 150 Q 150 250 100 350" class="bow"></path>
            <line id="bow-string" x1="100" y1="150" x2="100" y2="350" class="string"></line>
            <polygon id="arrow" class="arrow" points="100,250 150,250 150,245 180,250 150,255 150,250"
                     transform="translate(0,0)" style="visibility: visible;"></polygon>
        </g>
        <g id="crosshair">
            <line id="crosshair-v" x1="0" y1="0" x2="0" y2="0" class="crosshair"></line>
            <line id="crosshair-h" x1="0" y1="0" x2="0" y2="0" class="crosshair"></line>
        </g>
    </svg>

    @* === JAVASCRIPT CỦA GAME === *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.11.3/gsap.min.js"></script>
    <script>
        // === LOGIC MINIGAME BẮN CUNG ===
        (function () {
            // 1. DOM Elements
            const svg = document.getElementById("game-svg");
            const bowPivot = document.getElementById("bow-pivot");
            const bowString = document.getElementById("bow-string");
            const arrow = document.getElementById("arrow");
            const target = document.getElementById("target");
            const crosshairV = document.getElementById("crosshair-v");
            const crosshairH = document.getElementById("crosshair-h");

            // 2. Trạng thái game
            let isPulling = false;
            let isFiring = false;
            const pivot = { x: 100, y: 250 };

            // 3. Logic điều khiển (Aiming)
            svg.addEventListener("mousemove", function (e) {
                if (isFiring) return;
                const mouse = getMousePos(e);
                crosshairV.setAttribute("x1", mouse.x);
                crosshairV.setAttribute("y1", mouse.y - 10);
                crosshairV.setAttribute("x2", mouse.x);
                crosshairV.setAttribute("y2", mouse.y + 10);
                crosshairH.setAttribute("x1", mouse.x - 10);
                crosshairH.setAttribute("y1", mouse.y);
                crosshairH.setAttribute("x2", mouse.x + 10);
                crosshairH.setAttribute("y2", mouse.y);

                const dx = mouse.x - pivot.x;
                const dy = mouse.y - pivot.y;
                const angle = Math.atan2(dy, dx) * 180 / Math.PI;
                gsap.to(bowPivot, { duration: 0.1, rotation: angle, transformOrigin: "100px 250px" });

                if (isPulling) {
                    pullString(mouse, angle);
                }
            });

            // 4. Bắt đầu kéo
            svg.addEventListener("mousedown", function (e) {
                if (isFiring) return;
                isPulling = true;
            });

            // 5. Thả (Bắn)
            svg.addEventListener("mouseup", function (e) {
                if (isFiring || !isPulling) return;
                isPulling = false;
                isFiring = true;

                const mouse = getMousePos(e);
                const pullDistance = Math.min(Math.hypot(mouse.x - pivot.x, mouse.y - pivot.y), 100);
                const dx = mouse.x - pivot.x;
                const dy = mouse.y - pivot.y;
                const angleRad = Math.atan2(dy, dx);

                gsap.to(bowString, { duration: 0.1, attr: { x1: 100, y1: 150, x2: 100, y2: 350 } });

                gsap.to(arrow, {
                    duration: 0.8,
                    x: 800 + Math.cos(angleRad) * 50,
                    y: 250 + Math.sin(angleRad) * 50,
                    transformOrigin: "100px 250px",
                    onUpdate: function () {
                        if (checkHit()) {
                            this.pause();
                            handleHit();
                        }
                    },
                    onComplete: function () {
                        resetArrow();
                    }
                });
            });

            function pullString(mouse, angle) {
                const dx = mouse.x - pivot.x;
                const dy = mouse.y - pivot.y;
                const distance = Math.min(Math.hypot(dx, dy), 100);
                const pullX = pivot.x + Math.cos(angle * Math.PI / 180) * distance;
                const pullY = pivot.y + Math.sin(angle * Math.PI / 180) * distance;
                bowString.setAttribute("x1", pullX);
                bowString.setAttribute("y1", pullY);
                arrow.setAttribute("transform", `translate(${distance}, 0)`);
            }

            function checkHit() {
                const arrowBox = arrow.getBBox();
                const targetBox = target.getBBox();
                const arrowMatrix = arrow.getScreenCTM();
                const arrowPoint = svg.createSVGPoint();
                arrowPoint.x = arrowBox.x + arrowBox.width;
                arrowPoint.y = arrowBox.y + arrowBox.height / 2;
                const globalArrowPoint = arrowPoint.matrixTransform(arrowMatrix);
                const targetMatrix = target.getScreenCTM();
                const targetPoint = svg.createSVGPoint();
                targetPoint.x = targetBox.x;
                targetPoint.y = targetBox.y;
                const globalTargetPoint = targetPoint.matrixTransform(targetMatrix);

                return (
                    globalArrowPoint.x >= globalTargetPoint.x &&
                    globalArrowPoint.x <= globalTargetPoint.x + targetBox.width &&
                    globalArrowPoint.y >= globalTargetPoint.y &&
                    globalArrowPoint.y <= globalTargetPoint.y + targetBox.height
                );
            }

            function handleHit() {
                gsap.to(target.children, { duration: 0.1, fill: "lime", stagger: 0.05 });

                setTimeout(function () {
                    // (parent là window của _Layout.cshtml)
                    if (window.parent && window.parent.minigameWon) {
                        window.parent.minigameWon();
                    }
                }, 1000); // Chờ 1s
            }

            function resetArrow() {
                gsap.to(arrow, { duration: 0, x: 0, y: 0, transform: "translate(0,0)", opacity: 1 });
                arrow.style.visibility = "visible";
                isFiring = false;
            }

            function getMousePos(evt) {
                const CTM = svg.getScreenCTM();
                return {
                    x: (evt.clientX - CTM.e) / CTM.a,
                    y: (evt.clientY - CTM.f) / CTM.d
                };
            }
        })();
    </script>
</body>
</html>