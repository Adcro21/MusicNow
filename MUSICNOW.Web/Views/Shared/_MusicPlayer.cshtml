@* BỐ CỤC HTML MỚI CHO TRÌNH PHÁT NHẠC *@

@* Thẻ audio vẫn tồn tại nhưng bị ẩn đi. Nó là "cỗ máy" chính *@
<audio id="audio-player-fixed" style="display: none;"></audio>

<div id="music-player">

    <div class="player-track-info">
        <img id="player-cover-art" src="~/Content/image/music_placeholder.png" alt="Cover Art" class="player-cover-art" />
        <div class="player-track-details">
            <span id="player-title">Không có bài hát nào</span>
            <span id="player-artist">Ca sĩ</span>
        </div>

        @* Nút Like trên player *@
        <button id="player-like-btn" class="player-btn" title="Yêu thích">
            <i class="fa-regular fa-heart"></i>
        </button>
    </div>

    <div class="player-controls">

        <div class="player-control-buttons">
            <button id="player-repeat-btn" class="player-btn" title="Lặp lại">
                <i class="fa-solid fa-repeat"></i>
            </button>
            <button id="player-prev-btn" class="player-btn" title="Bài trước">
                <i class="fa-solid fa-backward-step"></i>
            </button>

            <button id="player-play-btn" class="player-btn" title="Phát">
                <i class="fa-solid fa-play"></i>
            </button>

            <button id="player-next-btn" class="player-btn" title="Bài tiếp theo">
                <i class="fa-solid fa-forward-step"></i>
            </button>
            <button id="player-playlist-btn" class="player-btn" title="Thêm vào Playlist">
                <i class="fa-solid fa-plus"></i>
            </button>
        </div>

        <div class="player-progress-container">
            <span id="player-current-time" class="player-time">0:00</span>
            <input type="range" id="player-progress-slider" class="progress-slider" min="0" max="100" value="0">
            <span id="player-duration" class="player-time">0:00</span>
        </div>
    </div>

    <div class="player-volume-controls">
        <button id="player-volume-btn" class="player-btn">
            <i class="fa-solid fa-volume-high"></i>
        </button>
        <input type="range" id="player-volume-slider" class="volume-slider" min="0" max="1" step="0.01" value="1">
    </div>

</div>