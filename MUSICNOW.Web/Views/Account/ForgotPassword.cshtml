@model MUSICNOW.Core.ViewModels.ForgotPasswordViewModel
@{
    ViewBag.Title = "Quên Mật Khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-6 offset-md-3" style="margin-top: 50px;">
        <h2>@ViewBag.Title</h2>
        <p>Vui lòng nhập email của bạn. Chúng tôi sẽ gửi một mã OTP để reset mật khẩu.</p>
        <hr />

        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { role = "form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group mb-3">
                @Html.LabelFor(m => m.Email, new { @class = "control-label" })
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <input type="submit" value="Gửi mã OTP" class="btn btn-primary" />
            </div>
        }
    </div>
</div>